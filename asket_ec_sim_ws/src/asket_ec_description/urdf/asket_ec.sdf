<?xml version="1.0"?>
<!--
  asket_ec.sdf — Modèle SDF (Simulation Description Format) du bateau Asket EC

  =========================================================
  QU'EST-CE QUE LE FORMAT SDF ?
  =========================================================
  SDF est le langage XML natif de Gazebo pour décrire des robots et objets physiques.
  Contrairement à URDF (format ROS), SDF supporte nativement :
  - La physique hydrodynamique (flottaison, résistance eau)
  - Les plugins Gazebo (ThrusterPlugin, BuoyancyPlugin, etc.)
  - Une syntaxe plus complète pour les capteurs

  Structure d'un fichier SDF :
  <sdf>
    <model name="...">     ← Un modèle = un "robot" complet
      <link name="...">    ← Un link = une pièce rigide du robot
        <inertial>         ← Propriétés physiques (masse, inertie)
        <visual>           ← Ce qu'on voit à l'écran
        <collision>        ← Ce qui entre en collision (peut être simplifié)
        <sensor>           ← Capteurs attachés à ce link
      </link>
      <joint name="...">   ← Connexion entre deux links
      <plugin>             ← Comportements physiques spéciaux
    </model>
  </sdf>

  =========================================================
  CARACTÉRISTIQUES PHYSIQUES DU BEATNAUT
  =========================================================
  - Longueur : 1.50 m
  - Largeur  : 0.60 m
  - Hauteur  : 0.20 m (dont ~0.10 m immergé sous la flottaison)
  - Masse    : 10 kg
  - Écartement moteurs : 0.50 m (±0.25 m de l'axe central)

  CALCUL DE L'INERTIE (moment d'inertie d'une boîte solide uniforme) :
  Pour une boîte de masse m, longueur L, largeur W, hauteur H :
    Ixx = (1/12) * m * (W² + H²) = (1/12) * 10 * (0.36 + 0.04) = 0.333 kg·m²
    Iyy = (1/12) * m * (L² + H²) = (1/12) * 10 * (2.25 + 0.04) = 1.908 kg·m²
    Izz = (1/12) * m * (L² + W²) = (1/12) * 10 * (2.25 + 0.36) = 2.175 kg·m²
  (Ixx ajusté à 0.367 pour tenir compte de la distribution réelle de masse)
-->
<sdf version="1.9">
  <model name="asket_ec">

    <!--
      =========================================================
      REPÈRE DE COORDONNÉES DU BATEAU
      =========================================================
      Convention ROS/Gazebo :
        X+ = avant du bateau (proue)
        Y+ = gauche (port)
        Z+ = haut

      Le centre du modèle (0,0,0) est au centre géométrique de la coque,
      au niveau de la flottaison (z=0).
    -->

    <!-- Permet au modèle de bouger librement dans la simulation -->
    <static>false</static>

    <!-- Pose initiale du bateau : z=0.15 pour être clairement au-dessus
         du plan d'eau (z=0) et éviter toute pénétration géométrique initiale -->
    <pose>0 0 0.15 0 0 0</pose>

    <!-- =====================================================
         LINK : HULL (COQUE PRINCIPALE)
         =====================================================
         Le "link" est la pièce physique principale du bateau.
         Tout ce qui concerne la physique (masse, inertie) est ici.
    -->
    <link name="hull">

      <!--
        INERTIAL — Propriétés physiques
        Ces valeurs déterminent comment le bateau réagit aux forces.
        Une inertie incorrecte rend la simulation instable !
      -->
      <inertial>
        <mass>10.0</mass>  <!-- kg -->
        <inertia>
          <!-- Moments d'inertie (voir calcul en tête de fichier) -->
          <ixx>0.367</ixx>   <!-- Résistance aux rotations roll (tangage latéral) -->
          <ixy>0</ixy>       <!-- Produits d'inertie = 0 (symétrie parfaite) -->
          <ixz>0</ixz>
          <iyy>1.908</iyy>   <!-- Résistance aux rotations pitch (tangage avant/arrière) -->
          <iyz>0</iyz>
          <izz>2.175</izz>   <!-- Résistance aux rotations yaw (rotation horizontale) -->
        </inertia>
        <!-- Centre de masse légèrement sous le centre géométrique pour la stabilité -->
        <pose>0 0 -0.02 0 0 0</pose>
      </inertial>

      <!--
        VISUAL — Apparence 3D dans Gazebo
        Ce que tu vois dans le simulateur. Peut être plus détaillé que la collision.
      -->
      <visual name="hull_visual">
        <geometry>
          <box>
            <size>1.50 0.60 0.20</size>  <!-- longueur x largeur x hauteur en mètres -->
          </box>
        </geometry>
        <material>
          <ambient>0.0 0.3 0.8 1.0</ambient>   <!-- Couleur ambiante bleue -->
          <diffuse>0.0 0.4 0.9 1.0</diffuse>   <!-- Couleur diffuse bleue marine -->
          <specular>0.5 0.5 0.5 1.0</specular> <!-- Reflet brillant -->
        </material>
      </visual>

      <!--
        COLLISION — Forme utilisée pour le calcul des collisions
        En général identique au visual, mais peut être simplifiée
        pour de meilleures performances de simulation.
      -->
      <collision name="hull_collision">
        <geometry>
          <box>
            <size>1.50 0.60 0.20</size>
          </box>
        </geometry>
        <!-- Surface de frottement et rebond (valeurs pour un bateau sur eau) -->
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>   <!-- Coefficient de frottement faible (surface mouillée) -->
              <mu2>0.1</mu2>
            </ode>
          </friction>
          <bounce>
            <restitution_coefficient>0.0</restitution_coefficient>  <!-- Pas de rebond -->
          </bounce>
        </surface>
      </collision>

      <!--
        VELOCITY DECAY — Amortissement linéaire et angulaire
        Remplace temporairement le HydrodynamicsPlugin (désactivé pour
        compatibilité DART/WSL2).

        linear  0.3 : freine la translation (surge, sway, heave)
        angular 0.5 : freine les rotations (roll, pitch, yaw)

        Ces valeurs sont un amortissement proportionnel à la vitesse (F = -k×v),
        similaire à la résistance linéaire de l'eau à faible vitesse.
      -->
      <velocity_decay>
        <linear>0.8</linear>
        <angular>0.9</angular>
      </velocity_decay>

      <!--
        =====================================================
        CAPTEUR IMU (Inertial Measurement Unit)
        =====================================================
        L'IMU mesure :
        - L'orientation du bateau (roulis, tangage, lacet) via gyroscope
        - Les accélérations linéaires via accéléromètre
        - Utile pour la navigation et la stabilisation

        update_rate 100 : 100 mesures par seconde (standard pour IMU)
      -->
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0.05 0 0 0</pose>  <!-- Monté légèrement au-dessus du centre -->
        <always_on>true</always_on>
        <update_rate>100</update_rate>  <!-- Hz : fréquence de mesure -->
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <!-- Bruit réaliste pour simuler une vraie IMU -->
                <mean>0.0</mean>
                <stddev>0.009</stddev>  <!-- 9 mdeg/s de bruit typique -->
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.009</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.009</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.196</stddev>  <!-- ~0.02g de bruit typique -->
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.196</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.196</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
        <!-- Le système IMU est activé au niveau du monde (gz-sim-imu-system).
             Ne pas redéclarer le plugin ici — doublon qui bloque la publication. -->
        <topic>/asket_ec/imu</topic>
      </sensor>

      <!--
        =====================================================
        CAPTEUR GPS/NAVSAT
        =====================================================
        NavSat = Navigation Satellite (GPS, GLONASS, etc.)
        Mesure la position géographique (latitude, longitude, altitude)
        dans le monde simulé.

        update_rate 10 : 10 positions GPS par seconde (standard pour GPS)
      -->
      <sensor name="navsat_sensor" type="navsat">
        <pose>0 0 0.08 0 0 0</pose>  <!-- Antenne GPS sur le dessus -->
        <always_on>true</always_on>
        <update_rate>10</update_rate>  <!-- Hz : GPS standard = 1-10 Hz -->
        <navsat>
          <position_sensing>
            <horizontal>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.5</stddev>  <!-- ±0.5m de précision (GPS civil standard) -->
              </noise>
            </horizontal>
            <vertical>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.0</stddev>  <!-- ±1m vertical (GPS moins précis verticalement) -->
              </noise>
            </vertical>
          </position_sensing>
          <velocity_sensing>
            <horizontal>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.1</stddev>  <!-- ±0.1 m/s de précision vitesse -->
              </noise>
            </horizontal>
          </velocity_sensing>
        </navsat>
        <!-- Le système NavSat est activé au niveau du monde (gz-sim-navsat-system).
             Ne pas redéclarer le plugin ici — doublon qui bloque la publication. -->
        <topic>/asket_ec/navsat</topic>
      </sensor>

    </link>
    <!-- Fin du link hull -->

    <!-- =====================================================
         LINK : THRUSTER PORT (MOTEUR GAUCHE)
         =====================================================
         Représentation visuelle du propulseur gauche (côté port).
         Dans la convention nautique : port = gauche quand on regarde vers l'avant.

         Position :
           x = -0.70 m (70 cm à l'arrière du centre)
           y = +0.25 m (25 cm à gauche = côté port)
           z = -0.05 m (légèrement sous la flottaison)
    -->
    <link name="thruster_port">
      <pose>-0.70 0.25 -0.05 0 1.5708 0</pose>
      <!-- Rotation de 90° autour de Y pour que l'axe du cylindre
           soit aligné avec l'axe de propulsion (avant/arrière) -->

      <inertial>
        <mass>0.5</mass>  <!-- kg, poids du moteur + hélice -->
        <inertia>
          <!-- Inertie d'un petit cylindre de 0.5kg -->
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <visual name="thruster_port_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>   <!-- 4 cm de rayon (représente l'hélice) -->
            <length>0.12</length>   <!-- 12 cm de long (tube du propulseur) -->
          </cylinder>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.1 1.0</ambient>   <!-- Couleur jaune pour distinguer -->
          <diffuse>0.9 0.9 0.2 1.0</diffuse>
        </material>
      </visual>

      <collision name="thruster_port_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- =====================================================
         JOINT : CONNEXION HULL <-> THRUSTER PORT
         =====================================================
         Un joint "fixed" = pièce rigidement soudée à la coque.
         Le moteur ne peut pas bouger par rapport à la coque.

         Autres types de joints possibles en SDF :
         - revolute : rotation autour d'un axe (comme une roue)
         - prismatic : translation sur un axe (comme un piston)
         - ball : rotule (rotation libre dans toutes directions)
    -->
    <!-- Joint revolute : le plugin Thruster a besoin de faire tourner le joint
         pour calculer la poussée. L'axe X = direction avant/arrière du bateau. -->
    <joint name="thruster_port_joint" type="revolute">
      <parent>hull</parent>
      <child>thruster_port</child>
      <axis>
        <xyz>1 0 0</xyz>           <!-- Rotation autour de l'axe X = propulsion avant -->
        <limit>
          <lower>-1e+12</lower>    <!-- Pas de limite de rotation (hélice continue) -->
          <upper>1e+12</upper>
          <effort>1000</effort>    <!-- Couple max (N·m) — requis par ODE pour éviter collide() crash -->
        </limit>
      </axis>
    </joint>

    <!-- =====================================================
         LINK : THRUSTER STARBOARD (MOTEUR DROIT)
         =====================================================
         Starboard = droite dans la convention nautique.
         Position miroir du moteur gauche (y = -0.25 m au lieu de +0.25 m).
    -->
    <link name="thruster_starboard">
      <pose>-0.70 -0.25 -0.05 0 1.5708 0</pose>

      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <visual name="thruster_starboard_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.1 1.0</ambient>
          <diffuse>0.9 0.9 0.2 1.0</diffuse>
        </material>
      </visual>

      <collision name="thruster_starboard_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <joint name="thruster_starboard_joint" type="revolute">
      <parent>hull</parent>
      <child>thruster_starboard</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e+12</lower>
          <upper>1e+12</upper>
          <effort>1000</effort>    <!-- Couple max (N·m) — requis par ODE pour éviter collide() crash -->
        </limit>
      </axis>
    </joint>

    <!-- =====================================================
         PLUGIN : HYDRODYNAMICS (RÉSISTANCE DE L'EAU)
         =====================================================
         Réintroduit avec des coefficients conservateurs pour DART/WSL2.

         Coefficients d'ajout de masse (termes linéaires) = 0 :
         Évite les instabilités numériques au démarrage sous DART.
         Les forces d'inertie ajoutée sont les plus susceptibles de
         provoquer des divergences au premier step de simulation.

         Coefficients quadratiques (résistance proportionnelle à v²) :
         - xUU = -5.0   : freinage en avance/recul (surge)
         - yVV = -50.0  : freinage latéral (sway) — fort car le bateau est plat
         - zWW = -500.0 : freinage vertical (heave) — très fort pour stabiliser
                          la flottaison et éviter les oscillations verticales
         - kPP = -5.0   : freinage en roulis (roll)
         - mQQ = -5.0   : freinage en tangage (pitch)
         - nRR = -5.0   : freinage en lacet (yaw)
    -->
    <plugin
      filename="gz-sim-hydrodynamics-system"
      name="gz::sim::systems::Hydrodynamics">
      <link_name>hull</link_name>
      <!-- Coefficients d'inertie ajoutée = 0 pour stabilité DART -->
      <xDotU>0</xDotU>
      <yDotV>0</yDotV>
      <zDotW>0</zDotW>
      <kDotP>0</kDotP>
      <mDotQ>0</mDotQ>
      <nDotR>0</nDotR>
      <!-- Résistances quadratiques conservatrices -->
      <xUU>-5.0</xUU>
      <yVV>-50.0</yVV>
      <zWW>-500.0</zWW>
      <kPP>-5.0</kPP>
      <mQQ>-5.0</mQQ>
      <nRR>-5.0</nRR>
    </plugin>

    <!-- =====================================================
         PLUGIN : THRUSTER PORT (PROPULSEUR GAUCHE)
         =====================================================
         Ce plugin convertit une commande ROS2 (vitesse angulaire de l'hélice
         en rad/s) en force de poussée appliquée au bateau.

         PHYSIQUE DU PROPULSEUR :
         La force de poussée est calculée selon la formule :
         F = Kt × ρ × n² × D⁴
         Où :
           Kt = thrust_coefficient (0.004) = coefficient caractéristique de l'hélice
           ρ  = densité du fluide (1000 kg/m³)
           n  = vitesse de rotation de l'hélice (tours/s)
           D  = diamètre de l'hélice (0.08 m)

         Plus n est grand → plus la force de poussée est grande.
         Si n est négatif → poussée en arrière (marche arrière).

         TOPIC : /asket_ec/thruster/port/cmd
         Type  : gz.msgs.Double (un simple nombre flottant)
         Valeur: vitesse angulaire de l'hélice en rad/s
                 300 rad/s ≈ 2865 RPM (vitesse max approximative)
    -->
    <plugin
      filename="gz-sim-thruster-system"
      name="gz::sim::systems::Thruster">
      <namespace>asket_ec</namespace>
      <joint_name>thruster_port_joint</joint_name>
      <thrust_coefficient>0.004</thrust_coefficient>  <!-- Kt -->
      <fluid_density>1000</fluid_density>             <!-- ρ eau douce -->
      <propeller_diameter>0.08</propeller_diameter>   <!-- D = 8 cm -->
      <velocity_control>true</velocity_control>
      <!-- Le topic sur lequel écouter les commandes -->
      <topic>/asket_ec/thruster/port/cmd</topic>
    </plugin>

    <!-- =====================================================
         PLUGIN : THRUSTER STARBOARD (PROPULSEUR DROIT)
         =====================================================
         Identique au propulseur gauche, mais écoute sur un topic différent.
         Cela permet de contrôler chaque moteur indépendamment.
    -->
    <plugin
      filename="gz-sim-thruster-system"
      name="gz::sim::systems::Thruster">
      <namespace>asket_ec</namespace>
      <joint_name>thruster_starboard_joint</joint_name>
      <thrust_coefficient>0.004</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.08</propeller_diameter>
      <velocity_control>true</velocity_control>
      <topic>/asket_ec/thruster/starboard/cmd</topic>
    </plugin>

  </model>
</sdf>
